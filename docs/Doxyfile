PROJECT_NAME           = "freqlib"
PROJECT_BRIEF          = "Text frequency analysis library — ASCII character and word counting"
PROJECT_NUMBER         = "1.0.0"
OUTPUT_DIRECTORY       = .
INPUT                  = ../include ../src
RECURSIVE              = NO
FILE_PATTERNS          = *.h *.c
OPTIMIZE_OUTPUT_FOR_C  = YES
